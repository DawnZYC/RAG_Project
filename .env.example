# 复制此文件为 .env，填入你的配置
# 注意：.env 文件不要提交到 git

# ── 必填 ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── 可选（括号内为默认值）─────────────────────────────────────────────────────

# 使用的 LLM 模型
# 可选：gpt-4o-mini（便宜快速）、gpt-4o（质量更好）
LLM_MODEL=gpt-4o-mini

# 嵌入模型（本地运行，不消耗 API 费用）
# 英文文档：BAAI/bge-small-en-v1.5
# 中文文档：BAAI/bge-small-zh-v1.5
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# 数据存储路径（本地运行时相对于项目根目录）
CHROMA_DIR=data/chroma
PROCESSED_DIR=data/processed
DB_PATH=data/logs/queries.db
